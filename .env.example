# Database
DATABASE_URL="postgresql://minddump:changeme@db:5432/minddump?schema=public"
DB_PASSWORD="changeme"

# Dev mode: set to "true" to skip authentication
SKIP_AUTH="false"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-secret-with-openssl-rand-base64-32"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Apple OAuth (optional)
APPLE_ID=""
APPLE_SECRET=""

# Gmail SMTP for notifications
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="your-email@gmail.com"

# MCP Server (pour accès distant depuis Claude mobile/web)
MCP_SECRET="generate-a-secret-with-openssl-rand-base64-32"
MINDDUMP_MCP_API_KEY="mdk_your-api-key-here"
